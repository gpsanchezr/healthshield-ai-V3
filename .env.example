# ╔══════════════════════════════════════════════════════════════╗
# ║       HealthShield AI — Variables de Entorno                ║
# ║  Copia este archivo como .env y completa los valores        ║
# ╚══════════════════════════════════════════════════════════════╝

# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=cambia-esto-por-una-clave-secreta-muy-larga-y-aleatoria
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Base de Datos ─────────────────────────────────────────────────────────────
# PostgreSQL (producción)
DATABASE_URL=postgresql://healthshield:password@localhost:5432/healthshield_db
DB_PASSWORD=securepassword

# SQLite para desarrollo rápido (sin PostgreSQL):
# DATABASE_URL=sqlite:///db.sqlite3

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# ── Redis + Celery (ETL asíncrono — opcional) ─────────────────────────────────
# Si no tienes Redis, el ETL funciona de forma síncrona (sin Celery)
REDIS_URL=redis://localhost:6379/0

# ── Machine Learning ──────────────────────────────────────────────────────────
ML_MODELS_PATH=./ml_models/
ML_RETRAIN_THRESHOLD=0.05

# ── ETL ───────────────────────────────────────────────────────────────────────
ETL_BATCH_SIZE=500

# ── IA Generativa (opcional — para análisis clínico narrativo) ────────────────
# Claude (Anthropic) — https://console.anthropic.com/
# Obtén tu key gratis en: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=

# Gemini (Google) — https://makersuite.google.com/app/apikey
# Obtén tu key gratis en: https://aistudio.google.com/
GEMINI_API_KEY=

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Timeouts y configuración adicional ───────────────────────────────────────
AI_TIMEOUT_SECONDS=20     # Timeout para llamadas a Claude/Gemini API
